[Unit]
Description=awgToolza Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/awg-bot
ExecStart=/opt/awg-bot/venv/bin/python /opt/awg-bot/run.py
Restart=on-failure
RestartSec=5
# конфиг с токеном и admin id
Environment=AWG_BOT_CONF=/etc/awg-bot.conf

[Install]
WantedBy=multi-user.target
